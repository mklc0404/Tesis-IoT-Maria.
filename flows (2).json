    {
        "id": "6a3c45a4781ec02a",
        "type": "function",
        "z": "eb8268d91c703453",
        "name": "function validacion",
        "func": "// Verificamos que msg.payload y msg.payload.data existan para evitar el TypeError\nif (msg.payload && msg.payload.data) {\n    \n    // Creamos el objeto limpio solo si hay datos\n    msg.payload = {\n        estacion: msg.payload.estacion || \"Nodo_01\",\n        temperatura: msg.payload.data.temp,\n        humedad: msg.payload.data.hum,\n        lluvia: msg.payload.data.precip,\n        timestamp: new Date() // Generamos el tiempo aquí mismo para tu tesis\n    };\n    \n    return msg;\n} else {\n    // Si no hay datos válidos, detenemos el flujo para que no marque error\n    return null;\n}",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 130,
        "y": 100,
        "wires": [
            [
                "d606301004f6d64e",
                "1e097d9eb7a44c7b"
            ]
        ]
    },
    {
        "id": "7aac34283b3b8e04",
        "type": "function",
        "z": "eb8268d91c703453",
        "name": "function SQL",
        "func": "// 1. Extraemos los valores\nvar estacion = String(msg.payload.estacion || \"Nodo_01\").trim();\nvar temp     = parseFloat(msg.payload.temperatura) || 0;\nvar hum      = parseFloat(msg.payload.humedad) || 0;\nvar precip   = parseFloat(msg.payload.lluvia) || 0;\n\n// 2. Construimos la instrucción SQL directamente como un solo texto\n// Usamos CURRENT_TIMESTAMP para que la base de datos ponga la hora exacta\nvar comandoSQL = \"INSERT INTO public.lecturas_clima (estacion, temperatura, humedad, precipitacion, fecha_registro) \" + \n                 \"VALUES ('\" + estacion + \"', \" + temp + \", \" + hum + \", \" + precip + \", CURRENT_TIMESTAMP) RETURNING *;\";\n\n// 3. Le pasamos el texto directamente al nodo (en ambas variables para asegurar)\nmsg.payload = comandoSQL;\nmsg.query = comandoSQL;\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 430,
        "y": 120,
        "wires": [
            [
                "4ce1edd8d4b3b284"
            ]
        ]
    },
