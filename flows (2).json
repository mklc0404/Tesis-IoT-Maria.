    {
        "id": "3bc95449c39eabb3",
        "type": "function",
        "z": "eb8268d91c703453",
        "name": "function temp",
        "func": "var temp = parseFloat(msg.payload.temperatura);\n\n// REGLA: Solo aceptar valores entre -10 y 50 grados (rango climático normal)\nif (temp >= -10 && temp <= 50) {\n    msg.payload = temp;\n    return msg;\n} else {\n    // Si el valor es loco (ej. 500), el sistema lo ignora y no guarda basura\n    node.warn(\"Valor de temperatura fuera de rango: \" + temp);\n    return null;\n}",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 140,
        "y": 180,
        "wires": [
            [
                "5a6b533944d1b218",
                "e76731835687c926"
            ]
        ]
    },
    {
        "id": "cd3d1bfd0d477b66",
        "type": "function",
        "z": "eb8268d91c703453",
        "name": "function hum",
        "func": "var hum = parseFloat(msg.payload.humedad);\n\n// REGLA: Solo aceptar valores entre 0 y 100 porcintos (rango climático normal)\nif (hum >= 0 && hum <= 100) {\n    msg.payload = hum;\n    return msg;\n} else {\n    // Si el valor es loco (ej. 200), el sistema lo ignora y no guarda basura\n    node.warn(\"Valor de humedad  fuera de rango: \" + hum);\n    return null;\n}",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 510,
        "y": 160,
        "wires": [
            [
                "6c9796e2ea4725d9",
                "e76731835687c926"
            ]
        ]
    },
    {
        "id": "add45450f1b1ba00",
        "type": "function",
        "z": "eb8268d91c703453",
        "name": "function precip",
        "func": "var precip = parseFloat(msg.payload.lluvia);\n\n// REGLA: La precipitación no puede ser negativa y 500mm es un límite de lluvia extrema\nif (precip >= 0 && precip <= 500) {\n    msg.payload = precip;\n    msg.topic = \"Precipitación\";\n    return msg;\n} else {\n    // Si el sensor envía un valor loco (ej. un pico de interferencia de 2000)\n    node.warn(\"Ruido detectado en sensor de lluvia: \" + precip);\n    return null;\n}",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
